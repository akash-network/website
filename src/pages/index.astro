---
import Hero from "@/components/home/hero/hero.astro";
import ProductShowcaseSection from "@/components/home/product-showcase.astro";
import InfraCarouselSection from "@/components/home/infra-carousel.astro";
import HowItWorksSection from "@/components/home/how-it-works.astro";
import NetworkGlobeSection from "@/components/home/network-globe.astro";
import RazerCaseStudySection from "@/components/home/razer-case-study.astro";
import TrustedBy from "@/components/home/trustedby/trusted-by.astro";
import GpuPricingSection from "@/components/home/gpu-pricing-section.astro";
import Layout from "@/layouts/layout.astro";
import { getEntry } from "astro:content";

const homepage = await getEntry("Homepage", "index");

const {
  heroSection,
} = homepage?.data;
---


<Layout
  classname="bg-background"
  headerClassName="bg-background dark:bg-[#030303] top-0 sticky z-[40] pt-4 pb-2.5 px-4"
  title="Akash Network - Decentralized Compute Marketplace"
  footerClassName="bg-background container"
  description="Akash is an open network that lets users buy and sell computing resources securely and efficiently. Purpose-built for public utility."
>
  <!-- Preload LCP hero image -->
  <link rel="preload" as="image" type="image/webp" imagesrcset="/images/heroNew1-1200w.webp 1200w, /images/heroNew1.webp 2274w" imagesizes="(max-width: 1136px) 100vw, 1136px" slot="head" />
  <!-- ContentSquare - deferred -->
  <script is:inline slot="head">
    window.addEventListener('load', function() {
      setTimeout(function() {
        var s = document.createElement('script');
        s.src = 'https://t.contentsquare.net/uxa/f3d653170e755.js';
        s.async = true;
        document.head.appendChild(s);
      }, 200);
    });
  </script>
  <div>
    <Hero heroSection={heroSection} />
    <div class="bg-background dark:bg-[#030303] w-full h-fit"><TrustedBy /></div>
    <div class="bg-background dark:bg-[#0D0D0E] w-full h-fit"><ProductShowcaseSection /></div>
    <div class="bg-background dark:bg-[#0D0D0E] w-full h-fit"><GpuPricingSection /></div>
    <div class="bg-background dark:bg-[#0D0D0E] w-full h-fit"><HowItWorksSection /></div>
    <div class="bg-background dark:bg-[#0D0D0E] w-full h-fit"><InfraCarouselSection /></div>
    <div class="bg-background dark:bg-[#0D0D0E] w-full h-fit"><RazerCaseStudySection /></div>
    <div class="bg-zinc-50 dark:bg-black w-full h-fit"><NetworkGlobeSection /></div>
  </div>
</Layout>
