---
import { type CollectionEntry, getCollection } from "astro:content";

import NextPrevNav from "@/components/development-pages/next-prev-nav.astro";
import TopMargin from "@/components/ui/top-margin.astro";
import Layout from "@/layouts/layout.astro";
import { proseClasses } from "@/lib/prose-classes";

export async function getStaticPaths() {
  const pages = await getCollection("Development_Current_Groups_Page");
  return pages.map((page) => ({
    params: { slug: page?.slug?.split("/")?.[0] },
    props: page,
  }));
}

type Props = CollectionEntry<"Development_Current_Groups_Page">;

const page = Astro.props;
const { Content, headings } = await page.render();
const pages = await getCollection("Development_Current_Groups_Page");

const nav: any = [];

pages.forEach((item) => {
  let mainLabel = item?.data?.category;
  mainLabel = mainLabel
    .split("-")
    .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

  const existingItem = nav.find((navItem: any) => navItem.label === mainLabel);
  if (existingItem) {
    existingItem.subItems.push({
      label: item.data.title,
      link: `/current-groups/${item.slug?.split("/")[0]}/`,
      enabled: true,
    });
  } else {
    nav.push({
      label: mainLabel,
      link: `/current-groups/${item?.slug?.split("/")[0]}/`,
      enabled: true,
      subItems: [
        {
          label: item.data.title,
          link: `/current-groups/${item.slug?.split("/")[0]}/`,
          enabled: true,
        },
      ],
    });
  }
});

function findPrevAndNextPages(nav: any, pathname: any) {
  let allItems: any = [];
  nav.forEach((category: any) => {
    if (category.subItems?.length > 0) allItems = allItems.concat(category.subItems);
  });
  const currentIndex = allItems.findIndex((item: any) => item.link === pathname);
  return {
    prevPage: currentIndex > 0 ? allItems[currentIndex - 1] : null,
    nextPage: currentIndex < allItems.length - 1 ? allItems[currentIndex + 1] : null,
  };
}

const pathname = new URL(Astro.request.url).pathname;
---

<Layout title={`${page.data.title} - Community Groups`} image="/meta-images/development.png">
  <TopMargin>
    <div class="grid grid-cols-12 gap-x-5 overflow-x-hidden">

      <!-- SIDEBAR -->
      <div class="sidebar-scroll sticky top-32 hidden h-screen overflow-auto md:col-span-3 md:block">
        <div class="flex flex-col gap-y-1">

          <!-- Back -->
          <a
            href="/development/community-groups/"
            class="mb-3 inline-flex items-center gap-1.5 text-sm font-medium text-para transition-colors hover:text-foreground"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Back
          </a>

          {nav?.map((navItem: any) => (
            <div class="mb-4">
              <!-- Category header -->
              <p class="mb-1 px-2 py-1 text-xs font-semibold uppercase tracking-wider text-para/60">
                {navItem.label}
              </p>
              <!-- Sub-items -->
              {navItem.subItems?.map((subItem: any) => (
                <a
                  href={subItem.link}
                  class={`block rounded-md px-2 py-1.5 text-sm transition-colors ${
                    pathname === subItem.link
                      ? "bg-gray-100 font-medium text-foreground dark:bg-background2"
                      : "text-para hover:bg-gray-100 hover:text-foreground dark:hover:bg-background2"
                  }`}
                >
                  {subItem.label}
                </a>
              ))}
            </div>
          ))}

        </div>
      </div>

      <!-- MAIN CONTENT -->
      <div class="col-span-12 mx-auto w-full md:col-span-9 md:pl-10">

        <!-- Mobile breadcrumbs -->
        <nav class="mt-6 flex items-center gap-1.5 text-sm md:hidden">
          <a
            href="/development/community-groups/"
            class="text-para transition-colors hover:text-foreground"
          >
            All Groups
          </a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-para/50">
            <path d="m9 18 6-6-6-6"/>
          </svg>
          <span class="font-medium text-foreground">{page.data.title}</span>
        </nav>

        <div class="mt-6 space-y-8 md:mt-0">

          <!-- Hero: title + description -->
          <div class="not-prose space-y-3">
            <h1 class="text-2xl font-semibold leading-tight tracking-tight text-foreground md:text-3xl">
              {page.data.title}
            </h1>
            <p class="text-sm font-normal leading-relaxed text-para">
              {page.data.description}
            </p>
          </div>

          <!-- Action buttons -->
          <div class="not-prose flex flex-wrap gap-2">
            <a
              href={page.data.discordLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-gray-100 dark:hover:bg-background2"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-foreground">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
              </svg>
              View on Discord
            </a>
            <a
              href={page.data.githubLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-gray-100 dark:hover:bg-background2"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              View on GitHub
            </a>
            <a
              href={page.data.meetings.link.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-gray-100 dark:hover:bg-background2"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
                <line x1="16" x2="16" y1="2" y2="6"/>
                <line x1="8" x2="8" y1="2" y2="6"/>
                <line x1="3" x2="21" y1="10" y2="10"/>
              </svg>
              Subscribe to Calendar
            </a>
          </div>

          <!-- Markdown content -->
          <article class={proseClasses + " cg-article overflow-x-auto"}>
            <Content />
          </article>
        </div>

        <NextPrevNav nav={findPrevAndNextPages(nav, pathname)} />
      </div>
    </div>
  </TopMargin>
</Layout>

<style>
  /* Hide duplicate h1 and its immediately following paragraph from markdown */
  .cg-article :global(h1:first-of-type) {
    display: none;
  }
  .cg-article :global(h1:first-of-type + p) {
    display: none;
  }

  /* All prose links — shadcn text link style, not red */
  .cg-article :global(a) {
    color: hsl(var(--foreground)) !important;
    text-decoration: underline !important;
    text-underline-offset: 4px;
    font-weight: 500;
    transition: color 0.15s ease;
  }
  .cg-article :global(a:hover) {
    color: hsl(var(--para)) !important;
  }

  /* Table link styling — no underline, "View" text with hover arrow */
  .cg-article :global(table a) {
    text-decoration: none !important;
    display: inline-flex;
    align-items: center;
    gap: 0;
    transition: gap 0.15s ease;
  }
  .cg-article :global(table a::after) {
    content: "›";
    display: inline-block;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    font-size: 1rem;
    line-height: 1;
  }
  .cg-article :global(table a:hover) {
    gap: 3px;
  }
  .cg-article :global(table a:hover::after) {
    opacity: 1;
    transform: translateX(0);
  }

  /* Typography — shadcn hierarchy */
  .cg-article :global(h1) {
    font-size: 1.5rem !important;
    font-weight: 600 !important;
    letter-spacing: -0.025em;
    color: hsl(var(--foreground)) !important;
  }
  .cg-article :global(h2) {
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: hsl(var(--foreground)) !important;
  }
  .cg-article :global(h3) {
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: hsl(var(--foreground)) !important;
  }
  .cg-article :global(h4) {
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    color: hsl(var(--foreground)) !important;
  }
  .cg-article :global(p) {
    color: hsl(var(--para)) !important;
    font-size: 0.875rem !important;
    line-height: 1.625 !important;
  }
  .cg-article :global(li) {
    color: hsl(var(--para)) !important;
    font-size: 0.875rem !important;
  }

  /* Table */
  .cg-article :global(table) {
    font-size: 0.875rem;
  }
  .cg-article :global(thead th) {
    color: hsl(var(--para)) !important;
    font-weight: 500;
  }
  .cg-article :global(td) {
    color: hsl(var(--para)) !important;
  }
</style>
