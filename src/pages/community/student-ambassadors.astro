          </ButtonLink>
        </div>
      </div>
    </section>
  </TopMargin>
</Layout>

<style>
  /* Path color dots — supporting neutral slate scale (Akash brand allows neutrals) */
  .path-dot--technical {
    background-color: #1e293b;
  }
  .path-dot--events {
    background-color: #475569;
  }
  .path-dot--content {
    background-color: #64748b;
  }
  .path-dot--community {
    background-color: #94a3b8;
  }

  .path-badge--technical {
    background-color: rgba(30, 41, 59, 0.08);
    color: #1e293b;
  }
  .path-badge--events {
    background-color: rgba(71, 85, 105, 0.08);
    color: #475569;
  }
  .path-badge--content {
    background-color: rgba(100, 116, 139, 0.08);
    color: #475569;
  }
  .path-badge--community {
    background-color: rgba(148, 163, 184, 0.12);
    color: #475569;
  }

  :global(.dark) .path-badge--technical,
  :global(.dark) .path-badge--events,
  :global(.dark) .path-badge--content,
  :global(.dark) .path-badge--community {
    background-color: rgba(148, 163, 184, 0.12);
    color: #cbd5e1;
  }

  /* Logo ticker — infinite horizontal scroll */
  .logo-ticker-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
  }

  .logo-ticker-track {
    width: max-content;
    animation: logo-ticker 40s linear infinite;
  }

  @keyframes logo-ticker {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-ticker-track {
      animation: none;
    }
  }
</style>

<script>
  /* Stats counters — animate on first scroll into view */
  function initStats(): void {
    const stats = document.querySelectorAll<HTMLElement>("[data-stat]");
    if (stats.length === 0) return;
    const animate = (el: HTMLElement): void => {
      const target = Number(el.dataset.statTarget ?? "0");
      const duration = 1200;
      const start = performance.now();
      const tick = (now: number): void => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = String(Math.round(target * eased));
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 },
    );
    stats.forEach((el) => observer.observe(el));
  }

  /* Filter + search */
  function initFilters(): void {
    const filterContainer = document.querySelector<HTMLElement>("[data-filters]");
    const searchInput = document.querySelector<HTMLInputElement>("[data-search]");
    const cards = document.querySelectorAll<HTMLElement>(".contribution-card");
    const noResults = document.querySelector<HTMLElement>("[data-no-results]");
    if (!filterContainer) return;

    let activePath = "all";

    const applyFilters = (): void => {
      const query = (searchInput?.value ?? "").trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const matchesPath =
          activePath === "all"
            ? true
            : activePath === "standout"
              ? card.dataset.featured === "true"
              : card.dataset.path === activePath;
        const blob = card.dataset.searchBlob ?? "";
        const matchesQuery = query === "" ? true : blob.includes(query);
        const show = matchesPath && matchesQuery;
        card.style.display = show ? "" : "none";
        if (show) visible += 1;
      });
      if (noResults) noResults.style.display = visible === 0 ? "" : "none";
    };

    filterContainer.addEventListener("click", (e: Event) => {
      const target = (e.target as HTMLElement).closest<HTMLButtonElement>(
        ".filter-btn",
      );
      if (!target) return;
      const path = target.dataset.path ?? "all";
      activePath = path;
      filterContainer.querySelectorAll<HTMLElement>(".filter-btn").forEach((btn) => {
        const isActive = btn === target;
        btn.dataset.active = String(isActive);
        btn.setAttribute("aria-pressed", String(isActive));
      });
      applyFilters();
    });

    searchInput?.addEventListener("input", applyFilters);
  }

  /* Ambassador carousel */
  function initCarousel(): void {
    const root = document.querySelector<HTMLElement>("[data-carousel]");
    const track = document.querySelector<HTMLElement>("[data-carousel-track]");
    const prev = document.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const next = document.querySelector<HTMLButtonElement>("[data-carousel-next]");
    if (!root || !track || !prev || !next) return;

    let offset = 0;
    const step = (): number => {
      const first = track.firstElementChild as HTMLElement | null;
      if (!first) return 0;
      const gap = 20;
      return first.offsetWidth + gap;
    };
    const maxOffset = (): number =>
      Math.max(0, track.scrollWidth - root.clientWidth);

    const update = (): void => {
      offset = Math.max(0, Math.min(offset, maxOffset()));
      track.style.transform = `translateX(-${offset}px)`;
    };

    prev.addEventListener("click", () => {
      offset -= step() * 2;
      update();
    });
    next.addEventListener("click", () => {
      offset += step() * 2;
      update();
    });
    window.addEventListener("resize", update);
  }

  initStats();
  initFilters();
  initCarousel();
</script>
