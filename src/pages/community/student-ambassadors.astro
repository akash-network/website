const totalContributions = contributions.length;
const ambassadorSet = new Set<string>();
contributions.forEach((c) => {
  c.ambassador.split(/\s*&\s*/).forEach((name) => ambassadorSet.add(name.trim()));
});
const totalAmbassadors = ambassadorSet.size;
const totalUniversities = new Set(contributions.map((c) => c.university)).size;

const pathLabels: Record<Path, string> = {
  technical: "Technical",
  events: "Events",
  content: "Content Creation",
  community: "Community Building",
};

const sortedContributions = [...contributions].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return 0;
});

const title = "The Akash Student Ambassador Program";
const description =
  "Real work, real impact — highlighting what our student ambassadors are building, writing, hosting, and growing across the globe.";
---

<Layout
  title={title}
  description={description}
  image="/meta-images/community.png"
>
  <TopMargin isNotContainer>
    {/* HERO */}
    <section
      class="not-prose relative overflow-hidden border-b border-defaultBorder bg-background"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-60 dark:opacity-40"
        style="background: radial-gradient(ellipse at 20% 50%, rgba(255,65,76,0.18) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(255,65,76,0.12) 0%, transparent 50%);"
      >
      </div>
      <div
        class="container relative mx-auto flex flex-col items-center px-4 py-16 text-center md:py-20"
      >
        <div class="mb-8 flex items-center justify-center">
          <img
            src={`${SHOWCASE}/akash-uni-pro-d.svg`}
            alt="Akash University Pro"
            class="block h-16 w-auto md:h-20 dark:hidden"
          />
          <img
            src={`${SHOWCASE}/akash-uni-pro-w.svg`}
            alt="Akash University Pro"
            class="hidden h-16 w-auto md:h-20 dark:block"
          />
        </div>
        <h1
          class="max-w-3xl text-4xl !font-semibold leading-[1.1] tracking-tight text-foreground md:text-5xl lg:text-6xl"
        >
          Ambassador
          <span class="font-instrument italic font-normal text-primary">
            Contributions
          </span>
          Showcase
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-para md:text-lg">
          Real work, real impact — highlighting what our student ambassadors are
          building, writing, hosting, and growing across the globe.
        </p>
        <div
          class="mt-10 flex flex-col flex-wrap items-center justify-center gap-3 sm:flex-row"
        >
          <ButtonLink
            className="mt-0"
            link="https://docs.google.com/forms/d/e/1FAIpQLScprUXYrjp9HdwUW_DdTu1UnOvmw2bMfJ0wVKZ1J653uuJsxQ/viewform"
            variant="primary"
            size="lg"
          >
            Submit your application
          </ButtonLink>
          <ButtonLink
            className="mt-0"
            link="https://x.com/AkashStudents"
            variant="secondary"
            size="lg"
          >
            Akash Students on X.com
          </ButtonLink>
          <ButtonLink
            className="mt-0"
            link="https://proximal-liver-375.notion.site/Akash-Student-Ambassador-Program-2dc7e695758c80d9a1f8f9749e063b51"
            variant="ghost"
            size="lg"
          >
            Learn More About University Program
          </ButtonLink>
        </div>
      </div>
    </section>

    {/* STATS */}
    <section
      class="not-prose border-b border-defaultBorder bg-background"
      data-stats-root
    >
      <div
        class="container mx-auto grid grid-cols-1 divide-y divide-defaultBorder px-4 sm:grid-cols-3 sm:divide-x sm:divide-y-0"
      >
        <div class="flex flex-col items-center gap-2 py-10 md:py-14">
          <span
            class="text-5xl font-bold tracking-tight text-foreground md:text-6xl"
            data-stat-target={totalContributions}
            data-stat
          >
            0
          </span>
          <span class="text-sm font-medium uppercase tracking-wider text-para">
            Total Contributions
          </span>
        </div>
        <div class="flex flex-col items-center gap-2 py-10 md:py-14">
          <span
            class="text-5xl font-bold tracking-tight text-foreground md:text-6xl"
            data-stat-target={totalAmbassadors}
            data-stat
          >
            0
          </span>
          <span class="text-sm font-medium uppercase tracking-wider text-para">
            Active Ambassadors
          </span>
        </div>
        <div class="flex flex-col items-center gap-2 py-10 md:py-14">
          <span
            class="text-5xl font-bold tracking-tight text-foreground md:text-6xl"
            data-stat-target={totalUniversities}
            data-stat
          >
            0
          </span>
          <span class="text-sm font-medium uppercase tracking-wider text-para">
            Universities
          </span>
        </div>
      </div>
    </section>

    {/* LOGO TICKER */}
    <section class="not-prose border-b border-defaultBorder bg-background py-12">
      <div class="logo-ticker-mask relative mx-auto w-full max-w-[1400px] overflow-hidden">
        <div class="logo-ticker-track flex items-center gap-16 whitespace-nowrap">
          {[...schoolLogos, ...schoolLogos].map((logo) => (
            <img
              src={logo.src}
              alt={logo.alt}
              class="h-10 w-auto flex-none object-contain opacity-70 grayscale dark:invert"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </section>

    {/* FILTERS + SEARCH */}
    <section class="not-prose bg-background pt-12">
      <div class="container mx-auto px-4">
        <div class="mb-3 text-sm font-medium uppercase tracking-wider text-para">
          Filter by path
        </div>
        <div
          class="mb-6 flex flex-wrap gap-2"
          role="tablist"
          aria-label="Filter contributions"
          data-filters
        >
          <button
            type="button"
            class="filter-btn rounded-full border border-defaultBorder px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-cardGray data-[active=true]:bg-foreground data-[active=true]:text-background"
