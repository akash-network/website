  path: Path;
  title: string;
  description: string;
  ambassador: string;
  university: string;
  month: string;
  link: string;
  pr?: boolean;
  featured?: boolean;
  images?: string[];
}

interface Ambassador {
  src: string;
  name: string;
  university: string;
}

interface Testimonial {
  initial: string;
  name: string;
  handle: string;
  body: string;
}

interface SchoolLogo {
