---
import FormattedDate from "@/components/formatted-date.astro";
import TopMargin from "@/components/ui/top-margin.astro";
import Layout from "@/layouts/layout.astro";
import { proseClasses } from "@/lib/prose-classes";
import { ArrowUpRight, ArrowLeft } from "lucide-react";
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type Contribution = CollectionEntry<"Community_Contributions_Page">;

export async function getStaticPaths() {
  const contributions = await getCollection("Community_Contributions_Page");
  return contributions.map((contribution) => ({
    params: { slug: contribution.slug },
    props: { contribution },
  }));
}

const { contribution } = Astro.props as { contribution: Contribution };
const { Content } = await contribution.render();
---

<Layout
  title={contribution.data.title}
  description={contribution.data.description}
  image="/meta-images/community.png"
>
  <TopMargin isNotContainer>
    <div class="mx-auto w-full max-w-[1100px] px-4 md:px-6 lg:px-8">
      <a
        href="/community/contributions/"
        class="mb-8 inline-flex items-center gap-1.5 text-sm text-para hover:text-foreground"
      >
        <ArrowLeft className="h-4 w-4" />
        Community Contributions
      </a>

      <div class="mt-4 grid grid-cols-12 md:gap-x-10 lg:gap-x-16">
        <div class="col-span-12 md:col-span-8">
          <div class="flex items-center gap-x-4">
            <a
              class="inline-flex items-center rounded-full bg-badgeColor px-3 py-1.5 text-xs font-medium text-iconText"
            >
              {contribution.data.categories[0]}
            </a>
          </div>

          <h1 class="mt-4 font-sans text-3xl md:mt-[18px] md:text-4xl lg:text-5xl">
            {contribution.data.title}
          </h1>

          <p class="mt-4 text-sm font-medium text-para md:text-base">
            by {contribution.data.contributors[0]}
            <span class="ml-2">
              &mdash; <FormattedDate date={contribution.data.pubDate} />
            </span>
          </p>
        </div>
      </div>

      <div class="mt-8 grid grid-cols-12 md:gap-x-10">
        <article class="col-span-12 md:col-span-8">
          <div class="overflow-hidden rounded-lg">
            {contribution.data.bannerImage ? (
              <Image
                src={contribution.data.bannerImage}
                alt={contribution.data.title}
                class="aspect-video w-full object-cover"
              />
            ) : (
              <img
                src="/images/contributions/thumbnail-background.png"
                alt={contribution.data.title}
                class="aspect-video w-full object-cover"
              />
            )}
          </div>

          <article class={proseClasses}>
            <Content />
          </article>

          {
            contribution.data.link && (
              <div class="mt-10 flex">
                <a
                  href={contribution.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-md border border-defaultBorder bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-background2"
                >
                  Read Original Post
                  <ArrowUpRight className="h-4 w-4" />
                </a>
              </div>
            )
          }
        </article>

        <aside class="sticky top-28 col-span-4 hidden h-screen space-y-10 md:block">
          <div>
            <p class="font-bold leading-none text-foreground">About the Author</p>
            <p class="mt-3 text-sm text-para">{contribution.data.contributors[0]}</p>
          </div>

          <div>
            <p class="font-bold leading-none text-foreground">Published</p>
            <p class="mt-3 text-sm text-para">
              <FormattedDate date={contribution.data.pubDate} />
            </p>
          </div>

          <div>
            <p class="font-bold leading-none text-foreground">Category</p>
            <div class="mt-3">
              <span class="inline-flex items-center rounded-full bg-badgeColor px-3 py-1.5 text-xs font-medium text-iconText">
                {contribution.data.categories[0]}
              </span>
            </div>
          </div>

          {
            contribution.data.link && (
              <div>
                <a
                  href={contribution.data.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-md border border-defaultBorder bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-background2"
                >
                  Read Original Post
                  <ArrowUpRight className="h-4 w-4" />
                </a>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </TopMargin>
</Layout>
