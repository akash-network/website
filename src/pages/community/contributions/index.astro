---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import TopMargin from "@/components/ui/top-margin.astro";
import Layout from "@/layouts/layout.astro";

const title = "Community Contributions";
const description =
  "A global community collaborating and contributing to the development of the Akash Network.";

const allContributions = await getCollection("Community_Contributions_Page");
const contributions = allContributions.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const categories = ["All Posts", "News", "Guides", "Articles"];
---

<Layout title={title} description={description} image="/meta-images/community.png">
  <TopMargin isNotContainer>
    <div class="mx-auto w-full max-w-[1260px] px-4 md:px-6 lg:px-8">
      <div class="mb-10">
        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          {title}
        </h1>
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-para md:text-base">
          {description}
        </p>
      </div>

      <div class="mb-8 flex flex-wrap gap-2">
        {
          categories.map((cat, i) => (
            <button
              data-category={cat}
              class={`filter-btn rounded-full border px-4 py-1.5 text-sm font-medium transition-colors ${
                i === 0
                  ? "border-foreground bg-foreground text-background"
                  : "border-defaultBorder bg-background text-para hover:border-foreground hover:text-foreground"
              }`}
            >
              {cat}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-1 items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          contributions.map((contribution) => (
            <div class="article-card h-full" data-category={contribution.data.categories[0]}>
              <a
                href={`/community/contributions/${contribution.slug}`}
                class="group flex h-full flex-col overflow-hidden rounded-lg border border-defaultBorder bg-background shadow-sm transition-all duration-200 hover:shadow-md"
              >
                <div class="h-48 w-full flex-shrink-0 overflow-hidden">
                  {contribution.data.bannerImage ? (
                    <Image
                      src={contribution.data.bannerImage}
                      alt={contribution.data.title}
                      width={800}
                      height={450}
                      class="h-full w-full object-cover"
                    />
                  ) : (
                    <img
                      src="/images/contributions/thumbnail-background.png"
                      alt={contribution.data.title}
                      class="h-full w-full object-cover"
                    />
                  )}
                </div>
                <div class="flex flex-1 flex-col gap-3 p-5">
                  <p class="text-sm text-para">{contribution.data.contributors[0]}</p>
                  <h3 class="line-clamp-2 text-base font-semibold leading-snug text-foreground">
                    {contribution.data.title}
                  </h3>
                  <div class="mt-auto pt-2">
                    <span class="inline-flex items-center rounded-full border border-defaultBorder bg-transparent px-3 py-1 text-xs font-medium text-foreground transition-colors group-hover:bg-badgeColor">
                      Read More
                    </span>
                  </div>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </TopMargin>
</Layout>

<script>
  function initFilters() {
    const filterBtns =
      document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".article-card");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");

        filterBtns.forEach((b) => {
          b.classList.remove("bg-foreground", "text-background", "border-foreground");
          b.classList.add("bg-background", "text-para", "border-defaultBorder", "hover:border-foreground", "hover:text-foreground");
        });
        btn.classList.remove("bg-background", "text-para", "border-defaultBorder", "hover:border-foreground", "hover:text-foreground");
        btn.classList.add("bg-foreground", "text-background", "border-foreground");

        cards.forEach((card) => {
          if (
            category === "All Posts" ||
            card.getAttribute("data-category") === category
          ) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  }

  initFilters();
  document.addEventListener("astro:page-load", initFilters);
</script>
