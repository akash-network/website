---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import TopMargin from "@/components/ui/top-margin.astro";
import Layout from "@/layouts/layout.astro";
import { Card } from "@/components/ui/card";
import { ChevronRight } from "lucide-react";

const title = "Community Contributions";
const description =
  "A global community collaborating and contributing to the development of the Akash Network.";

const allContributions = await getCollection("Community_Contributions_Page");
const contributions = allContributions.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const categories = ["All Posts", "News", "Guides", "Articles"];
---

<Layout title={title} description={description} image="/meta-images/community.png">
  <TopMargin isNotContainer>
    <div class="container">
      <div class="mb-10 space-y-5 md:mb-[60px] lg:mb-20">
        <h1 class="text-4xl font-semibold leading-tight tracking-tight text-foreground md:text-5xl lg:text-6xl">
          {title}
        </h1>
        <p class="max-w-2xl text-base font-normal text-para">
          {description}
        </p>
      </div>

      <!-- Category Switcher -->
      <div class="mb-10 overflow-x-auto scrollbar-hide">
        <div class="inline-flex items-center rounded-full bg-[#F4F4F5] dark:bg-background2 p-1.5">
          {
            categories.map((cat, i) => (
              <button
                data-category={cat}
                class={`filter-btn whitespace-nowrap rounded-full px-5 py-2 text-sm font-medium transition-all duration-200 ${
                  i === 0
                    ? "bg-background text-foreground shadow-sm"
                    : "text-para hover:text-foreground"
                }`}
              >
                {cat}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 items-stretch gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          contributions.map((contribution) => (
            <div class="article-card h-full" data-category={contribution.data.categories[0]}>
              <a href={`/community/contributions/${contribution.id}`} class="block h-full">
                <Card className="group h-full cursor-pointer transition-all duration-300 hover:shadow-xl hover:shadow-black/5 dark:hover:shadow-black/20">
                  <div class="flex h-full flex-col gap-5 p-6">
                    <div class="overflow-hidden rounded-lg">
                      {contribution.data.bannerImage ? (
                        <Image
                          src={contribution.data.bannerImage}
                          alt={contribution.data.title}
                          width={800}
                          height={450}
                          class="h-44 w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-[1.03] group-hover:brightness-105"
                        />
                      ) : (
                        <img
                          src="/images/contributions/thumbnail-background.png"
                          alt={contribution.data.title}
                          class="h-44 w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-[1.03] group-hover:brightness-105"
                        />
                      )}
                    </div>
                    <p class="text-xs font-normal text-para">{contribution.data.contributors[0]}</p>
                    <h3 class="text-xl font-semibold leading-snug text-foreground">
                      {contribution.data.title}
                    </h3>
                    <div class="mt-auto pt-1">
                      <div class="flex h-9 w-full items-center justify-center gap-1.5 rounded-md border bg-transparent px-3 text-xs font-medium text-foreground shadow-sm transition-colors group-hover:bg-neutral-200 dark:group-hover:bg-badgeColor">
                        Read More<ChevronRight size={13} className="shrink-0 transition-transform duration-200 group-hover:translate-x-0.5" />
                      </div>
                    </div>
                  </div>
                </Card>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </TopMargin>
</Layout>

<script>
  function initFilters() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".article-card");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");

        filterBtns.forEach((b) => {
          b.classList.remove("bg-background", "text-foreground", "shadow-sm");
          b.classList.add("text-para");
        });
        btn.classList.remove("text-para");
        btn.classList.add("bg-background", "text-foreground", "shadow-sm");

        cards.forEach((card) => {
          if (
            category === "All Posts" ||
            card.getAttribute("data-category") === category
          ) {
            card.style.display = "";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  }

  initFilters();
  document.addEventListener("astro:page-load", initFilters);
</script>
