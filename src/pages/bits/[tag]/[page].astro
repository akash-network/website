---
import BitsSearchDialog from "@/components/blog/bits-search-dialog";
import Pagination from "@/components/pagination.astro";
import BitsTag from "@/components/ui/bits-tag.astro";
import FormattedDate from "@/components/formatted-date.astro";
import Layout from "@/layouts/layout.astro";
import type { PaginateFunction } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

type BitsPost = CollectionEntry<"Bits">;

export async function getStaticPaths({
  paginate,
}: {
  paginate: PaginateFunction;
}) {
  const posts = (await getCollection("Bits"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => {
      return (
        new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
      );
    });

  const tags: string[] = [];
  posts.forEach((post) => {
    post.data.tags.forEach((tag: string) => {
      if (!tags.includes(tag)) tags.push(tag);
    });
  });

  return tags.flatMap((tag) => {
    const filteredPosts = posts.filter((post) =>
      post.data.tags.some(
        (t: string) => t.toLowerCase() === tag.toLowerCase(),
      ),
    );

    return paginate(filteredPosts, {
      params: { tag: tag.toLowerCase().replaceAll(" ", "-") },
      pageSize: 12,
      props: { currentTag: tag, allTags: tags },
    });
  });
}

const { page, currentTag, allTags } = Astro.props;
const pathName = Astro.url.pathname.split("/");
---

<Layout
  title={`${currentTag} — Bits by Akash Network`}
  description="Short-form insights on AI, compute, and the open cloud from the Akash Network team."
>
  <div class="container mt-[72px] md:mt-[96px]">
    <h1 class="mb-10 text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl">
      Akash Bits
    </h1>

    <div
      class="flex flex-col items-start justify-between gap-x-5 border-b pb-5 lg:flex-row lg:border-none"
    >
      <div
        class="sidebar-scroll flex max-w-full items-center justify-start gap-2 overflow-auto pb-1"
      >
        <BitsTag
          active={pathName[1]?.toLowerCase() === "bits" && !pathName[2]}
          href="/bits"
        >
          All Posts
        </BitsTag>

        {
          allTags.map((tag: string) => (
            <BitsTag
              href={`/bits/${tag.toLowerCase().replaceAll(" ", "-")}/1`}
              active={
                pathName[2]?.toLowerCase() ===
                tag.toLowerCase().replaceAll(" ", "-")
              }
            >
              {tag.charAt(0).toUpperCase() + tag.slice(1)}
            </BitsTag>
          ))
        }
      </div>

      <div class="hidden lg:block">
        <BitsSearchDialog client:load />
      </div>
    </div>

    <div class="mt-5 flex justify-end lg:hidden">
      <BitsSearchDialog client:load />
    </div>

    <div class="container mt-20 space-y-10">
      <h1 class="text-3xl md:text-4xl lg:text-5xl">
        {currentTag.charAt(0).toUpperCase() + currentTag.slice(1)}
      </h1>

      <div
        class="grid grid-cols-1 gap-x-16 gap-y-10 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          page.data.map((post: BitsPost) => (
            <a class="flex cursor-pointer" href={`/bits/${post.id}`}>
              <div class="group flex flex-col duration-100 ease-in">
                <div class="aspect-video overflow-hidden rounded-lg bg-badgeColor">
                  {post.data.bannerImage ? (
                    <Image
                      src={post.data.bannerImage}
                      alt={`Banner image for ${post.data.title}`}
                      width={1200}
                      height={1200}
                      format="webp"
                      class="h-full w-full object-cover shadow-sm transition-all duration-500 ease-in-out group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="h-full w-full bg-gradient-to-br from-primary/20 to-badgeColor" />
                  )}
                </div>

                <div class="mt-4">
                  <div class="flex items-center gap-x-4">
                    <p class="text-2xs font-medium text-linkText md:text-sm">
                      By {post.data.author}
                    </p>
                    {post.data.tags[0] && (
                      <span class="inline-flex items-center rounded-full bg-badgeColor px-3 py-1.5 text-xs font-medium text-iconText">
                        {post.data.tags[0]}
                      </span>
                    )}
                  </div>

                  <h3 class="mt-2 line-clamp-2 text-base font-semibold md:mt-4 md:text-xl">
                    {post.data.title}
                  </h3>

                  <p class="mt-3 line-clamp-2 text-sm text-linkText md:mt-6 md:text-base">
                    {post.data.description}
                  </p>

                  <div class="mt-4 flex items-center gap-x-2 text-linkText">
                    <p class="text-2xs font-medium md:text-sm">5 Min. Read</p>
                    <div class="size-1 rounded-full bg-linkText" />
                    <p class="text-2xs font-medium md:text-sm">
                      <FormattedDate date={post.data.pubDate} />
                    </p>
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <Pagination page={page} />
    </div>
  </div>
</Layout>
