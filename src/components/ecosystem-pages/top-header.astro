---
import Categories from "./categories-mobile";
import SearchDialog from "./search-dialog";
const astroUrl = Astro.url;
const pathName = astroUrl.pathname.split("/");

const { tags, title = "Explore the Akash Ecosystem", description, hideFilters = false } = Astro.props;
---

<div class="space-y-5 mb-10 md:mb-[60px] lg:mb-20">
  <h1 class="text-4xl font-semibold leading-tight tracking-tight text-foreground md:text-5xl lg:text-6xl">
    {title}
  </h1>
  {description && (
    <p class="max-w-2xl text-base font-normal text-para">{description}</p>
  )}
</div>

{!hideFilters && (
  <div class="flex items-center justify-between pb-6 md:hidden">
    <Categories
      client:load
      tags={tags}
      page={pathName?.[2]}
    />
    <SearchDialog client:load currentPath={astroUrl.pathname} />
  </div>
)}
