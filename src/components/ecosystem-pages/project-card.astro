---
import { Image } from "astro:assets";
import { DiscordIcon, GithubIcon, TwitterIcon } from "../header/icons";
import { ChevronRight } from "lucide-react";
import DescriptionExpand from "./description-expand";

const {
  description,
  title,
  button,
  image,
  githubLink,
  twitterLink,
  discordLink,
  websiteLink,
  isTool = false,
} = Astro.props;

const isClickable = !!websiteLink;
const buttonLabel = isTool ? button?.label ?? "Visit" : "View project";
---

<div class="group h-full md:px-0">
  {isClickable ? (
    <div class="flex h-full flex-col rounded-lg border bg-card px-5 pb-5 pt-5 shadow-sm transition-shadow hover:shadow-md">
      <div class="overflow-hidden rounded-md">
        <Image
          class="w-full transform object-contain grayscale transition-all duration-500 ease-in-out group-hover:scale-[1.03] group-hover:brightness-105 group-hover:grayscale-0"
          src={image}
          alt={`banner image for ${title}`}
          width={1200}
          format="webp"
          loading="lazy"
        />
      </div>

      <div class="mt-4 flex flex-1 flex-col">
        <div class="flex items-center justify-between gap-2">
          <h4 class="text-base font-semibold leading-tight tracking-tight text-foreground">
            {title}
          </h4>
          <a
            href={websiteLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-para transition-colors hover:bg-badgeColor hover:text-foreground"
          >
            <TwitterIcon className="size-4 shrink-0" />
          </a>
        </div>
        <div class="flex-1">
          <DescriptionExpand description={description} client:load />
        </div>
        <div class="mt-auto pt-4">
          <a
            href={websiteLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-full items-center justify-center gap-1.5 rounded-md border bg-transparent px-3 text-xs font-medium text-foreground shadow-sm transition-colors hover:bg-neutral-200 dark:hover:bg-badgeColor"
          >
            {buttonLabel}<ChevronRight size={13} className="shrink-0 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </div>
  ) : (
    <div class="flex h-full flex-col rounded-lg border bg-card px-5 pb-5 pt-5 shadow-sm">
      <div class="overflow-hidden rounded-md">
        <Image
          class="aspect-[12/7] w-full transform object-contain grayscale transition-all duration-500 ease-in-out group-hover:scale-[1.03] group-hover:brightness-105 group-hover:grayscale-0"
          src={image}
          alt={`banner image for ${title}`}
          width={1200}
          format="webp"
          loading="lazy"
        />
      </div>

      <div class="mt-4">
        <h4 class="text-base font-semibold leading-tight tracking-tight text-foreground">
          {title}
        </h4>

        {(twitterLink || discordLink || githubLink) && (
          <div class="mt-4 flex items-center gap-x-4">
            {twitterLink && (
              <a href={twitterLink} target="_blank" class="block cursor-pointer text-lightForeground transition-colors hover:text-foreground">
                <TwitterIcon />
              </a>
            )}
            {discordLink && (
              <a href={discordLink} target="_blank" class="block cursor-pointer text-lightForeground transition-colors hover:text-foreground">
                <DiscordIcon />
              </a>
            )}
            {githubLink && (
              <a href={githubLink} target="_blank" class="block cursor-pointer text-lightForeground transition-colors hover:text-foreground">
                <GithubIcon />
              </a>
            )}
          </div>
        )}
        <DescriptionExpand description={description} client:load />
      </div>
    </div>
  )}
</div>
