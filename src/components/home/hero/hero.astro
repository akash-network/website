---
import TryAkashForm from "@/components/ui/try-akash-form";
import type { CollectionEntry } from "astro:content";
import clsx from "clsx";
import { Info } from "lucide-react";
import HeroLetterHeadline from "./HeroLetterHeadline.astro";
import Slider from "./slider.astro";

interface Props {
  heroSection: CollectionEntry<"Homepage">["data"]["heroSection"];
}

const { heroSection } = Astro.props;
const pathname = Astro.url.pathname;

const tiles = [
  {
    title: "Deploy AI models<br />on AkashML",
    description: "Run AI Inference models on a high-performance managed API.",
    image: "/images/heroNew1.png",
    imageWebp: "/images/heroNew1.webp",
    imageWebpSmall: "/images/heroNew1-1200w.webp",
    url: "https://akashml.com",
    buttonText: "Explore AkashML Playground",
  },
  {
    title: "Browse Templates on<br />Akash Console",
    description:
      "Explore pre-configured environments for Llama-3, DeepSeek, and more.",
    image: "/images/heroNew2.png",
    imageWebp: "/images/heroNew2.webp",
    imageWebpSmall: "/images/heroNew2-1200w.webp",
    url: "https://console.akash.network/templates",
    buttonText: "Explore Templates",
  },
  {
    title: "Become an<br />Akash Provider",
    description: "Monetize your servers by joining the network.",
    image: "/images/heroNew3.png",
    imageWebp: "/images/heroNew3.webp",
    imageWebpSmall: "/images/heroNew3-1200w.webp",
    url: "https://provider-console.akash.network",
    buttonText: "Become an Akash Provider",
  },
];

---

<section class="relative overflow-hidden bg-[#FCFCFC] dark:bg-[#030303]">
  <!-- <div class="glow"></div> -->
  <div class="container relative z-[2] pt-7 md:pt-[50px]">
    {
      pathname.includes("meetingconfirmation") && (
        <div class="relative mx-auto mt-10 flex w-fit items-center justify-center gap-2  rounded-lg border !border-primary px-4 py-3 text-sm text-primary">
          <Info className="size-4 shrink-0" />
          Thanks for booking your meeting, we look forward to speaking with you!
        </div>
      )
    }
    <HeroLetterHeadline
      lines={["Decentralized Cloud", "for AI's Next Frontier"]}
      class={clsx(
        "mx-auto text-center font-sans font-semibold text-foreground [letter-spacing:-2.4px] [font-size:clamp(2.25rem,6vw,4.5rem)] [line-height:1.0]",
        pathname.includes("meetingconfirmation") ? "mt-7" : "mt-10",
      )}
    />

    <p
      class="mx-auto mt-4 text-center text-sm text-para/75"
      set:html={heroSection.description}
    />

    <div class="mt-12 flex flex-col justify-center gap-3">
      <div class="flex justify-center" style="min-height:48px;">
        <TryAkashForm client:load type="hero" />
      </div>
      <div
        class="mx-auto flex items-center gap-2 rounded-full border bg-background2 px-4 py-2 text-center text-xs dark:bg-[#242429]/45"
      >
        <span>💸</span>
        <p class="text-[12.4px] text-[#8C8E91]">Get up to $100 in GPU credits</p>
      </div>
    </div>

    <div class="mt-12 md:mt-16">
      <div class="mx-auto max-w-[1440px] xl:px-0">
        <div class="mx-auto max-w-[960px] pb-6 pt-6 md:pt-8">
          <div
            class="flex flex-col gap-5 md:flex-row md:items-start"
            id="hero-product-tiles"
          >
            {
              tiles.map((tile, i) => (
                <div class="flex flex-1 flex-col">
                  <div class="w-full px-5 md:px-0">
                    <Slider
                      tileIndex={i}
                      title={tile.title}
                      description={tile.description}
                      url={tile.url}
                    />
                  </div>

                  {/* Mobile: progress bar + image below each card (only visible when active) */}
                  <div class="hero-mobile-block pl-5 md:hidden">
                    <div class="min-h-0">
                      <div class="hero-mobile-line relative">
                        <div class="h-px w-full bg-black/20 dark:bg-white/20" />
                        <div
                          class="hero-progress hero-progress-mobile absolute left-0 top-0 h-px bg-black dark:bg-white w-0"
                          data-tile={i}
                        />
                      </div>
                      <div
                        class="hero-mobile-image relative group overflow-hidden pl-4 pt-4"
                        data-tile={i}
                      >
                        <picture>
                          <source
                            srcset={`${tile.imageWebpSmall} 1200w, ${tile.imageWebp} 2274w`}
                            sizes="100vw"
                            type="image/webp"
                          />
                          <img
                            src={tile.image}
                            alt=""
                            width="1137"
                            height="481"
                            loading={i === 0 ? "eager" : "lazy"}
                            decoding={i === 0 ? "auto" : "async"}
                            class="h-[350px] w-full block rounded-tl-2xl object-cover object-left-top"
                          />
                        </picture>
                        <div class="hero-image-overlay opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                          <a
                            href={tile.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="hero-visit-btn"
                          >
                            {tile.buttonText}
                            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M0.665039 0.665039H7.33171M7.33171 0.665039V7.33171M7.33171 0.665039L0.665039 7.33171" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          {/* Desktop: progress bars */}
          <div class="mt-5 hidden gap-5 px-1 md:flex">
            {
              tiles.map((_, i) => (
                <div class="relative flex-1">
                  <div class="h-px w-full bg-black/20 dark:bg-white/20" />
                  <div
                    class="hero-progress hero-progress-desktop absolute left-0 top-0 h-px bg-black dark:bg-white w-0"
                    data-tile={i}
                  />
                </div>
              ))
            }
          </div>
        </div>
      </div>

      {/* Desktop: image container */}
      <div class="hidden md:block">
        <div class="mx-auto max-w-[1136px] px-4 pb-0 pt-4">
          <div class="relative group" style="aspect-ratio: 2274/962;">
            {
              tiles.map((tile, i) => (
                <div
                  class={`hero-desktop-image-container absolute inset-0 overflow-hidden rounded-t-[20px] transition-opacity duration-500 ease-in-out ${i === 0 ? "opacity-100" : "opacity-0"}`}
                  data-tile={i}
                >
                  <picture>
                    <source
                      srcset={`${tile.imageWebpSmall} 1200w, ${tile.imageWebp} 2274w`}
                      sizes="(max-width: 1136px) 100vw, 1136px"
                      type="image/webp"
                    />
                    <img
                      src={tile.image}
                      alt=""
                      width="1137"
                      height="481"
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding={i === 0 ? "auto" : "async"}
                      fetchpriority={i === 0 ? "high" : "auto"}
                      class="w-full block"
                    />
                  </picture>
                  <div class="hero-image-overlay opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                    <a
                      href={tile.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hero-visit-btn"
                    >
                      {tile.buttonText}
                      <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.665039 0.665039H7.33171M7.33171 0.665039V7.33171M7.33171 0.665039L0.665039 7.33171" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
    
  </div>
</section>

<style>
  @keyframes heroProgressFill {
    from {
      width: 0%;
    }
    to {
      width: 100%;
    }
  }

  .hero-progress.active {
    animation: heroProgressFill 5s linear forwards;
  }

  .hero-progress.completed {
    width: 100%;
    animation: none;
  }

  /* Mobile block: hidden by default, shown when active */
  @media (max-width: 767px) {
    .hero-mobile-block {
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      margin-top: 0;
      overflow: hidden;
      transition:
        grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.3s ease,
        margin-top 0.3s ease;
    }

    .hero-mobile-block.active {
      grid-template-rows: 1fr;
      opacity: 1;
      margin-top: 0.75rem;
    }
  }

  .hero-mobile-image {
    margin-top: 1rem;
  }

  .hero-image-overlay {
    background: rgba(20, 20, 22, 0.85);
    border: 1.12708px solid rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(3px);
    border-radius: 16px 16px 0px 0px;
    z-index: 10;
    position: absolute;
    bottom: 0;
  }

  @media (min-width: 768px) {
    .hero-image-overlay {
      top: 16px;
      left: 16px;
      right: 16px;
    }
  }

  @media (max-width: 767px) {
    .hero-image-overlay {
      top: 16px;
      left: 16px;
      right: 0;
    }
  }

  .hero-visit-btn {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    padding: 8px 32px;
    gap: 8px;
    width: fit-content;
    min-width: 264px;
    height: 40px;
    background: #E5E5E5;
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    color: #171717;
    font-size: 14px;
    font-weight: 500;
    transition: filter 0.2s ease;
  }

  .hero-visit-btn:hover {
    filter: brightness(0.9);
  }
</style>

<script>
  function setupHeroTiles() {
    const TILE_COUNT = 3;
    let current = 0;


    const tiles = document.querySelectorAll<HTMLButtonElement>(".hero-tile");
    const desktopBars = document.querySelectorAll<HTMLElement>(
      ".hero-progress-desktop",
    );
    const mobileBars = document.querySelectorAll<HTMLElement>(
      ".hero-progress-mobile",
    );
    const desktopImages = document.querySelectorAll<HTMLElement>(
      ".hero-desktop-image-container",
    );
    const mobileBlocks =
      document.querySelectorAll<HTMLElement>(".hero-mobile-block");

    if (tiles.length === 0) return;

    function activate(index: number) {
      current = index;

      tiles.forEach((tile, i) => {
        const isActive = i === index;
        tile.dataset.active = isActive ? "true" : "";

        // Style updates
        const title = tile.querySelector(".hero-tile-title");
        if (isActive) {
          tile.classList.add("dark:border-white/20", "dark:bg-[#29292b]");
          tile.classList.remove("dark:border-white/10", "dark:bg-[#1b1b1d]", "md:mt-3");
          
          if (title) {
            title.classList.add("text-[#171717]", "dark:text-white");
            title.classList.remove("text-[#86868b]");
          }
        } else {
          tile.classList.add("dark:border-white/10", "dark:bg-[#1b1b1d]", "md:mt-3");
          tile.classList.remove("dark:border-white/20", "dark:bg-[#29292b]");
          
          if (title) {
            title.classList.add("text-[#86868b]");
            title.classList.remove("text-[#171717]", "dark:text-white");
          }
        }
      });

      // Desktop progress bars
      desktopBars.forEach((bar, i) => {
        bar.classList.remove("active", "completed");
        bar.style.width = "";
        bar.style.animationPlayState = "running";

        if (i < index) {
          bar.classList.add("completed");
        } else if (i === index) {
          void bar.offsetWidth;
          bar.classList.add("active");
        } else {
          bar.style.width = "0%";
        }
      });

      // Mobile progress bars
      mobileBars.forEach((bar, i) => {
        bar.classList.remove("active", "completed");
        bar.style.width = "";
        bar.style.animationPlayState = "running";

        if (i < index) {
          bar.classList.add("completed");
        } else if (i === index) {
          void bar.offsetWidth;
          bar.classList.add("active");
        } else {
          bar.style.width = "0%";
        }
      });

      // Desktop images — crossfade via opacity only (no layout changes)
      desktopImages.forEach((img, i) => {
        if (i === index) {
          img.classList.remove("opacity-0");
          img.classList.add("opacity-100");
        } else {
          img.classList.remove("opacity-100");
          img.classList.add("opacity-0");
        }
      });

      // Mobile blocks
      mobileBlocks.forEach((block, i) => {
        block.classList.toggle("active", i === index);
      });
    }

    // Event Listeners
    [...desktopBars, ...mobileBars].forEach((bar) => {
      bar.addEventListener("animationend", () => {
        if (bar.offsetParent !== null) {
          activate((current + 1) % TILE_COUNT);
        }
      });
    });

    let resizeTimer: number;
    const handleResize = () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        activate(current);
      }, 200);
    };
    window.addEventListener("resize", handleResize);

    // Initial activation
    activate(0);

    // Cleanup for View Transitions
    document.addEventListener("astro:before-swap", () => {
      window.removeEventListener("resize", handleResize);
    }, { once: true });
  }

  // Initialize on every page load (View Transitions compatible)
  document.addEventListener("astro:page-load", setupHeroTiles);
</script>
