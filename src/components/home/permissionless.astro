---
interface Feature {
  icon: string;
  title: string;
  subtitle: string;
  description: string;
}

const features: Feature[] = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M5 5H5.01M5 15H5.01M3 1H17C18.1046 1 19 1.89543 19 3V7C19 8.10457 18.1046 9 17 9H3C1.89543 9 1 8.10457 1 7V3C1 1.89543 1.89543 1 3 1ZM3 11H17C18.1046 11 19 11.8954 19 13V17C19 18.1046 18.1046 19 17 19H3C1.89543 19 1 18.1046 1 17V13C1 11.8954 1.89543 11 3 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Heavy Iron",
    subtitle: "Enterprise Clusters\nH100 • A100 • A6000...",
    description:
      "High-availability interconnected clusters for massive training runs.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M1 16H19M4 1H16C17.1046 1 18 1.89543 18 3V11C18 12.1046 17.1046 13 16 13H4C2.89543 13 2 12.1046 2 11V3C2 1.89543 2.89543 1 4 1Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Edge & Inference",
    subtitle: "Consumer Grade\nRTX 4090 • 3090 • 3080...",
    description:
      "Ultra-low cost chips perfect for inference, rendering, and gaming.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M22 12C22 17.5228 17.5228 22 12 22M22 12C22 6.47715 17.5228 2 12 2M22 12H2M12 22C6.47715 22 2 17.5228 2 12M12 22C9.43223 19.3038 8 15.7233 8 12C8 8.27674 9.43223 4.69615 12 2M12 22C14.5678 19.3038 16 15.7233 16 12C16 8.27674 14.5678 4.69615 12 2M2 12C2 6.47715 6.47715 2 12 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "The Network",
    subtitle: "Censorship-Resistant\nSovereign Cloud",
    description:
      "No vendor lock-in. No de-platforming. No single point of failure.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M4.00048 14.0002C3.81125 14.0008 3.62571 13.9477 3.46543 13.8471C3.30516 13.7465 3.17671 13.6025 3.09503 13.4318C3.01335 13.2611 2.98177 13.0707 3.00398 12.8828C3.02619 12.6949 3.10126 12.5171 3.22048 12.3702L13.1205 2.17016C13.1947 2.08444 13.2959 2.02652 13.4075 2.0059C13.519 1.98527 13.6342 2.00318 13.7342 2.05667C13.8342 2.11016 13.9131 2.19606 13.9578 2.30027C14.0026 2.40448 14.0106 2.52081 13.9805 2.63016L12.0605 8.65016C12.0039 8.80169 11.9849 8.96468 12.0051 9.12517C12.0253 9.28566 12.0841 9.43884 12.1766 9.57159C12.269 9.70434 12.3923 9.81268 12.5358 9.88732C12.6793 9.96197 12.8387 10.0007 13.0005 10.0002H20.0005C20.1897 9.99952 20.3752 10.0526 20.5355 10.1532C20.6958 10.2538 20.8242 10.3978 20.9059 10.5685C20.9876 10.7392 21.0192 10.9296 20.997 11.1175C20.9748 11.3054 20.8997 11.4832 20.7805 11.6302L10.8805 21.8302C10.8062 21.9159 10.705 21.9738 10.5935 21.9944C10.482 22.0151 10.3668 21.9972 10.2668 21.9437C10.1667 21.8902 10.0879 21.8043 10.0431 21.7001C9.9984 21.5958 9.9904 21.4795 10.0205 21.3702L11.9405 15.3502C11.9971 15.1986 12.0161 15.0356 11.9959 14.8752C11.9757 14.7147 11.9168 14.5615 11.8244 14.4287C11.732 14.296 11.6087 14.1876 11.4652 14.113C11.3217 14.0384 11.1622 13.9996 11.0005 14.0002H4.00048Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`,
    title: "Velocity",
    subtitle: "Deployment Speed\n< 60 Seconds",
    description:
      "Time from configuration to first active container.",
  },
];
---

<section class="w-full text-[#171717] dark:text-white py-20 lg:py-[120px]">
  <div class="container">

    <div class="text-center mb-16">
      <h2 class="text-[28px] font-semibold leading-[34px]">
        Permissionless Infrastructure. Unlimited Supply.
      </h2>
      <p class="mt-2 text-[#8A8F98] dark:text-[#8A8F9D] text-base md:text-lg">
        Access a global network of high-<br class="block md:hidden" />performance compute on demand.
      </p>
    </div>

    <div class="flex overflow-x-auto lg:grid lg:grid-cols-4 gap-12 lg:overflow-visible scrollbar-hide">

      {features.map((feature) => (
        <div class="flex min-w-[260px] flex-col gap-4 lg:min-w-0">

          <div
            class="flex items-center justify-center h-12 w-12 rounded-lg bg-transparent dark:bg-[#191818] border border-[#E3E3E3] dark:border-[#383838] text-[#171717] dark:text-[#FAFAFA]"
            set:html={feature.icon}
          />

          <div class="space-y-4">
            <h3 class="text-xl font-semibold line-clamp-2">
              {feature.title}
            </h3>

            <p class="font-normal text-base md:text-[17px] text-[#171717] dark:text-white whitespace-pre-line line-clamp-2">
              {feature.subtitle}
            </p>

            <p class="font-normal text-base md:text-[17px] text-[#8A8F98] dark:text-[#8A8F9D] leading-relaxed max-w-xs line-clamp-2">
              {feature.description}
            </p>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>