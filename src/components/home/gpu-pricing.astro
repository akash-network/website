---
import { getEntry } from "astro:content";
import { BASE_API_URL } from '@/lib/constants'

const content = await getEntry("Homepage", "index");
const data = content.data.gpuPricing;

const gpuModels = ["H200", "H100", "A100"];

const staticPrices = {
  H200: { aws: 7.91, gcp: 10.44, coreweave: 6.31 },
  H100: { aws: 6.88, gcp: 14.19, coreweave: 6.16 },
  A100: { aws: 3.43, gcp: 4.03, coreweave: 2.70 }
};

const backupAkashPrices  = {
  H200: 2.59,
  H100: 1.34,
  A100: 1.06
};

// const backupAkashPrices  = {
//   H200: 0,
//   H100: 0,
//   A100: 0
// };

---

<section>
<div class="container-nav-3">

<!-- HEADER -->

<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">

<div>

<h2 class="text-[32px] md:text-4xl lg:text-5xl font-semibold">
{data.title}
</h2>

<p class="text-[#86868B] mt-2 md:mt-3 text-sm md:text-base">
{data.subtitle}
</p>

</div>

<a
href={data.ctaLink}
class="md:inline-flex hidden items-center gap-2 rounded-full border border-black/20 dark:border-white/20 px-8 py-2 text-sm text-[#171717] dark:text-white transition-all duration-300 hover:bg-white/30 dark:hover:bg-white/5 w-fit mt-auto"
>

{data.ctaText}

<svg width="20" height="20" viewBox="0 0 24 24">
<path d="M9 6L15 12L9 18" fill="none" stroke="currentColor" stroke-width="2"/>
</svg>

</a>

</div>

<hr class="border-black/10 dark:border-white/10 border-t my-8"/>

<p class="text-[#86868B] mb-2 text-sm md:text-base">
Choose a GPU Model
</p>


<!-- DESKTOP CONTROLS -->

<div class="hidden md:flex flex-wrap items-center gap-4 mb-10">

<!-- GPU COUNT -->

<div class="flex items-center justify-center gap-3 h-[52px] px-4 bg-white counter-shadow rounded-full">

<button id="gpu-dec" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8H12.6666" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<span id="gpu-count" class="text-[18px] font-medium text-[#1D1D1F] w-8 text-center">
1
</span>

<button id="gpu-inc" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8.00004H12.6666M7.99992 3.33337V12.6667" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

</div>

<!-- GPU SELECTOR -->

<div id="gpu-selector-desktop"
class="relative flex items-center h-[54px] p-[6px] gap-[12px] bg-[#F5F5F7] border border-[#F0F0F0] gpu-tab-shadow rounded-full">

<div id="tab-slider"
class="absolute top-[6px] left-0 h-[42px] w-[72px] bg-white gpu-tab-shadow rounded-[20px] transition-all duration-500 ease-out"></div>

{gpuModels.map((gpu)=>(
<button
class="gpu-tab relative z-10 w-[72px] h-[42px] flex items-center justify-center pl-1 rounded-[20px] text-[18px] font-medium transition-all duration-300 text-[#86868B]"
data-gpu={gpu}
>
{gpu}
</button>
))}

</div>

<!-- HOURS -->

<div class="flex items-center justify-center gap-3 h-[52px] px-4 bg-white counter-shadow rounded-full">

<button id="hour-dec" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8H12.6666" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<span id="hour-count" class="text-[18px] font-medium text-[#1D1D1F] w-8 text-center">
1h
</span>

<button id="hour-inc" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8.00004H12.6666M7.99992 3.33337V12.6667" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

</div>

</div>


<!-- MOBILE CONTROLS -->

<div class="md:hidden mb-10 flex flex-col gap-4">

<!-- GPU SELECTOR -->

<div id="gpu-selector-mobile"
class="relative flex items-center w-full h-[54px] p-[6px] gap-[12px] bg-[#F5F5F7] border border-[#F0F0F0] gpu-tab-shadow rounded-full">

<div id="tab-slider-mobile"
class="absolute top-[6px] left-0 h-[42px] bg-white gpu-tab-shadow rounded-[20px] transition-all duration-500 ease-out"></div>

{gpuModels.map((gpu)=>(
<button
class="gpu-tab-mobile relative z-10 flex-1 h-[42px] flex items-center justify-center pl-1 rounded-[20px] text-[18px] font-medium transition-all duration-300 text-[#86868B]"
data-gpu={gpu}
>
{gpu}
</button>
))}

</div>

<div class="flex justify-between gap-4">

<div class="flex items-center justify-center gap-3 h-[52px] px-4 bg-white counter-shadow rounded-full">
<button id="gpu-dec-mobile" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8H12.6666" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>
<span id="gpu-count-mobile" class="text-[18px] font-medium text-[#1D1D1F] w-8 text-center">1</span>
<button id="gpu-inc-mobile" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8.00004H12.6666M7.99992 3.33337V12.6667" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>
</div>

<div class="flex items-center justify-center gap-3 h-[52px] px-4 bg-white counter-shadow rounded-full">
<button id="hour-dec-mobile" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8H12.6666" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>
<span id="hour-count-mobile" class="text-[18px] font-medium text-[#1D1D1F] w-8 text-center">1h</span>
<button id="hour-inc-mobile" class="w-7 h-7 bg-white rounded-full flex items-center justify-center counter-shadow">
  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M3.33325 8.00004H12.6666M7.99992 3.33337V12.6667" stroke="#86868B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>
</div>

</div>

</div>



<!-- BARS -->

<div id="pricing-bars" class="space-y-3 md:space-y-4">

<!-- AKASH -->

<div id="row-akash" class="provider-row flex flex-col md:flex-row md:items-center md:gap-2 group/akash">

<div class="w-44 text-black dark:text-[#A6FA99] flex gap-2 items-center font-medium text-base">
<svg width="40" height="37" viewBox="0 0 40 37" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M22.714 21.8882L26.6378 26.2634L28.0054 28.831H20.0029L15.9995 21.8882H22.714Z" fill="currentColor"/>
  <path d="M28.0032 28.8317L32 21.8889L23.9998 8H15.9995L28.0032 28.8317Z" fill="currentColor"/>
  <path d="M12.0001 14.9414H20.0004L12.0034 28.8303L8 21.8875L12.0001 14.9414Z" fill="currentColor"/>
</svg>
Akash
</div>

<div class="flex items-center w-full bg-transparent border border-black/10 dark:border-white/10 h-[40px] md:h-[44px] rounded group-hover/akash:bg-black/5 group-hover/akash:dark:bg-white/5 transition-colors duration-300">

<div id="bar-akash"
class="bg-[#8BFE79] dark:bg-[#A6FA99] h-[39px] md:h-[43px] rounded flex items-center justify-end px-4 text-black transition-[width] duration-700 ease-out w-fit min-w-fit text-lg md:text-xl font-semibold">

<span id="emoji-akash"></span>
<span id="price-akash"></span>

</div>

<div class="w-full flex justify-between px-2 gap-2">
<span id="save-percent"
class="inline-flex bg-[#8BFE79] dark:bg-[#A6FA99] text-[#0C3205] px-4 py-2 rounded-full text-xs md:text-sm whitespace-nowrap font-medium">
Save %
</span>

<a href="https://console.akash.network/"
class="hidden sm:group-hover/akash:inline-flex transition-all duration-300 bg-black dark:bg-white text-white dark:text-[#171717] hover:scale-110 px-4 py-2 rounded-full text-sm whitespace-nowrap items-center gap-1">
<span class="font-medium">{data.deployText}</span>
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M5.25 10.5L8.75 7L5.25 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
</a>
</div>

</div>

</div>


<!-- AWS -->

<div id="row-aws" class="provider-row flex flex-col md:flex-row md:items-center md:gap-2">

<div class="w-44 text-[#8A8F98] flex gap-2 items-center font-medium text-base">
  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
