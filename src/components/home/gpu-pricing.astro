<style>

.counter-shadow {
box-shadow:0px 1px 3px rgba(0,0,0,0.1),0px 1px 2px -1px rgba(0,0,0,0.1);
}

.gpu-tab-shadow {
box-shadow:0px 1px 5px rgba(0,0,0,0.06);
}

.gpu-tab:hover,
.gpu-tab-mobile:hover{
color: black;
}

.gpu-tab.active,
.gpu-tab-mobile.active{
color: black;
}

</style>

<script is:inline type="module" define:vars={{ backupAkashPrices, staticPrices, BASE_API_URL }}>

let akashPrices = { ...backupAkashPrices };

const CACHE_KEY = "akash-gpu-prices";
const CACHE_TTL = 1000 * 60 * 30; // 30 minutes

function loadCachedPrices() {
  try {
    const raw = localStorage.getItem(CACHE_KEY);
    if (!raw) return null;

    const parsed = JSON.parse(raw);
    if (!parsed?.data || !parsed?.timestamp) return null;

    const isExpired = Date.now() - parsed.timestamp > CACHE_TTL;
    if (isExpired) return null;

    return parsed.data;
  } catch {
    return null;
  }
}

function saveCachedPrices(prices) {
  try {
    localStorage.setItem(
      CACHE_KEY,
      JSON.stringify({
        data: prices,
        timestamp: Date.now(),
      })
    );
  } catch {}
}

const cachedPrices = loadCachedPrices();
if (cachedPrices) {
  akashPrices = { ...backupAkashPrices, ...cachedPrices };
}

let gpu="H200"
let gpuCount=1
let hours=1

const $=id=>document.getElementById(id)

const tabs=document.querySelectorAll(".gpu-tab")
const tabsMobile=document.querySelectorAll(".gpu-tab-mobile")

const slider=$("tab-slider")
const sliderMobile=$("tab-slider-mobile")

const gpuCountEl=$("gpu-count")
const gpuCountMobileEl=$("gpu-count-mobile")

const hourCountEl=$("hour-count")
const hourCountMobileEl=$("hour-count-mobile")

const gpuInc=$("gpu-inc")
const gpuDec=$("gpu-dec")
const gpuIncMobile=$("gpu-inc-mobile")
const gpuDecMobile=$("gpu-dec-mobile")

const hourInc=$("hour-inc")
const hourDec=$("hour-dec")
const hourIncMobile=$("hour-inc-mobile")
const hourDecMobile=$("hour-dec-mobile")

let activeDesktopTab=tabs[0]
let activeMobileTab=tabsMobile[0]

tabs[0].classList.add("active")
tabsMobile[0].classList.add("active")

function moveSlider(tab,slider){

const container=slider.parentElement
const offset=tab.getBoundingClientRect().left-container.getBoundingClientRect().left

slider.style.width=tab.offsetWidth+"px"
slider.style.transform=`translateX(${offset}px)`

}

function initSliders(){

if(slider)moveSlider(activeDesktopTab,slider)
if(sliderMobile)moveSlider(activeMobileTab,sliderMobile)

}

setTimeout(initSliders,50)

tabs.forEach(tab=>{
tab.onclick=()=>{

tabs.forEach(t=>t.classList.remove("active"))
tab.classList.add("active")

gpu=tab.dataset.gpu
activeDesktopTab=tab

moveSlider(tab,slider)
update()

}
})

tabsMobile.forEach(tab=>{
tab.onclick=()=>{

tabsMobile.forEach(t=>t.classList.remove("active"))
tab.classList.add("active")

gpu=tab.dataset.gpu
activeMobileTab=tab

moveSlider(tab,sliderMobile)
update()

}
})

window.addEventListener("resize",initSliders)

function renderCounters(){

gpuCountEl.textContent=gpuCount
gpuCountMobileEl.textContent=gpuCount

hourCountEl.textContent=`${hours}h`
hourCountMobileEl.textContent=`${hours}h`

}

gpuInc.onclick=()=>{
gpuCount++
renderCounters()
update()
}

gpuDec.onclick=()=>{
if(gpuCount>1){
gpuCount--
renderCounters()
update()
}
}

gpuIncMobile.onclick=gpuInc.onclick
gpuDecMobile.onclick=gpuDec.onclick

hourInc.onclick=()=>{
hours++
renderCounters()
update()
}

hourDec.onclick=()=>{
if(hours>1){
hours--
renderCounters()
update()
}
}

hourIncMobile.onclick=hourInc.onclick
hourDecMobile.onclick=hourDec.onclick


function update(){

const akash=akashPrices[gpu]||0
const aws=staticPrices[gpu].aws
const gcp=staticPrices[gpu].gcp
const core=staticPrices[gpu].coreweave

const prices={
akash:akash*gpuCount*hours,
aws:aws*gpuCount*hours,
gcp:gcp*gpuCount*hours,
core:core*gpuCount*hours
}

const unit=hours===1?'hr':`${hours}hrs`

const values=Object.values(prices)

const min=Math.min(...values)
const max=Math.max(...values)

const isMobile=window.innerWidth<768
const isTablet=window.innerWidth>=768 && window.innerWidth<1024

let maxWidth=70

if(isMobile)maxWidth=95
else if(isTablet)maxWidth=80

function width(val){

if(max===min)return maxWidth

const ratio=(val-min)/(max-min)

return 25+ratio*(maxWidth-25)

}

$("bar-akash").style.width=width(prices.akash)+"%"
$("bar-aws").style.width=width(prices.aws)+"%"
$("bar-gcp").style.width=width(prices.gcp)+"%"
$("bar-core").style.width=width(prices.core)+"%"

$("price-akash").textContent=`$${prices.akash.toFixed(2)}/${unit}`
$("price-aws").textContent=`$${prices.aws.toFixed(2)}/${unit}`
$("price-gcp").textContent=`$${prices.gcp.toFixed(2)}/${unit}`
$("price-core").textContent=`$${prices.core.toFixed(2)}/${unit}`


/* ---------- DYNAMIC ORDERING ---------- */

const entries = Object.entries(prices).sort((a,b)=>a[1]-b[1])

setTimeout(()=>{

  const container=$("pricing-bars")

  entries.forEach(([provider])=>{
    const row=document.getElementById(`row-${provider}`)
    if(row)container.appendChild(row)
  })

},700)


/* ---------- RESET EMOJIS ---------- */

$("emoji-akash").textContent=""
$("emoji-aws").textContent=""
$("emoji-gcp").textContent=""
$("emoji-core").textContent=""

const cheapest=entries[0][0]

$(`emoji-${cheapest}`).textContent="🔥 "


/* ---------- COLOR LOGIC ---------- */

document.querySelectorAll("#bar-akash,#bar-aws,#bar-gcp,#bar-core").forEach(bar=>{
bar.classList.remove("bg-[#8BFE79]","dark:bg-[#A6FA99]")
bar.classList.add("bg-[#1D1D1F]","dark:bg-[#F5F5F7]")
})

const cheapestBar=document.getElementById(`bar-${cheapest}`)

if(cheapestBar){
cheapestBar.classList.remove("bg-[#1D1D1F]","dark:bg-[#F5F5F7]")
cheapestBar.classList.add("bg-[#8BFE79]","dark:bg-[#A6FA99]")
}


/* ---------- SAVE PERCENT ---------- */

let save=0

const others=[prices.aws,prices.gcp,prices.core]
const minOther=Math.min(...others)

if(minOther>0 && prices.akash<minOther){
save=((minOther-prices.akash)/minOther)*100
}

$("save-percent").textContent=`Save ${save.toFixed(0)}%`

requestAnimationFrame(adjustMobileArrow)

}


async function fetchRealtimePrices() {
  try {
    const res = await fetch(`${BASE_API_URL}/v1/gpu-prices`);
    if (!res.ok) throw new Error("API failed");

    const data = await res.json();
    const models = data?.models || [];

    const findPrice = (name) =>
      models.find((m) => m?.model?.toLowerCase().includes(name))
        ?.price?.weightedAverage;

    const nextPrices = { ...backupAkashPrices };

    const h200 = findPrice("h200");
    const h100 = findPrice("h100");
    const a100 = findPrice("a100");

    if (h200 != null) nextPrices.H200 = Number(h200.toFixed(2));
    if (h100 != null) nextPrices.H100 = Number(h100.toFixed(2));
    if (a100 != null) nextPrices.A100 = Number(a100.toFixed(2));

    akashPrices = nextPrices;
    saveCachedPrices(nextPrices);
    update();
  } catch (error) {
    console.warn("Failed to fetch real-time prices:", error);

    const cached = loadCachedPrices();
    if (cached) {
      akashPrices = { ...backupAkashPrices, ...cached };
    } else {
      akashPrices = { ...backupAkashPrices };
    }

    update();
  }
}

function adjustMobileArrow(){

const text=document.getElementById("mobile-deploy-text")
const arrow=document.getElementById("mobile-deploy-arrow")

if(!text||!arrow)return

const lineHeight=parseFloat(getComputedStyle(text).lineHeight)
const lines=Math.round(text.offsetHeight/lineHeight)

arrow.classList.remove("h-3.5","w-3.5","h-5","w-5")

if(lines>1){
arrow.classList.add("h-5","w-5")
}else{
arrow.classList.add("h-3.5","w-3.5")
}

}

update()
adjustMobileArrow()
renderCounters()
fetchRealtimePrices()

</script>