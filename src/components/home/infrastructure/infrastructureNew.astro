---
interface Feature {
  title: string;
  description: {
    primary: string;
    secondary: string;
  };
  image: string;
  imageWebp: string;
  mobileImage: string;
  mobileImageWebp: string;
}

const features: Feature[] = [
  {
    title: "Train 3x Longer",
    description: {
      primary:
        "H100s for $1.33/hr vs AWS at $3.93/hr.",
      secondary:
        "Get nearly 3 hours of compute for the price of 1. Transparent pricing, no hidden fees.",
    },
    image: "/images/infrastructure/feat1.png",
    imageWebp: "/images/infrastructure/feat1.webp",
    mobileImage: "/images/infrastructure/feat1sm.png",
    mobileImageWebp: "/images/infrastructure/feat1sm.webp",
  },
  {
    title: "Ray Distributed Clusters",
    description: {
      primary:
        "Scale training instantly.",
      secondary:
        "Spin up multi-node Ray clusters to train and fine-tune massive models without DevOps overhead.",
    },
    image: "/images/infrastructure/feat2.png",
    imageWebp: "/images/infrastructure/feat2.webp",
    mobileImage: "/images/infrastructure/feat2sm.png",
    mobileImageWebp: "/images/infrastructure/feat2sm.webp",
  },
  {
    title: "1-Click Templates",
    description: {
      primary:
        "Deploy faster.",
      secondary:
        "Launch pre-configured environments for Llama, Mistral, and Stable Diffusion in seconds.",
    },
    image: "/images/infrastructure/feat3.png",
    imageWebp: "/images/infrastructure/feat3.webp",
    mobileImage: "/images/infrastructure/feat3sm.png",
    mobileImageWebp: "/images/infrastructure/feat3sm.webp",
  },
  {
    title: "Docker Native",
    description: {
      primary:
        "No refactoring required.",
      secondary:
        "If it runs in a container, it runs here. Full Kubernetes support with zero vendor lock-in.",
    },
    image: "/images/infrastructure/feat4.png",
    imageWebp: "/images/infrastructure/feat4.webp",
    mobileImage: "/images/infrastructure/feat4sm.png",
    mobileImageWebp: "/images/infrastructure/feat4sm.webp",
  },
];
---

<section class="w-full text-white pt-20 pb-10 container-nav-3">
    <!-- Header -->
    <div class="text-center mb-14">
      <h2 class="text-[28px] md:text-[40px] font-semibold leading-[36px]">
        The Infrastructure <br class="block md:hidden" /> for AI & Data
      </h2>
      <p class="text-[#8C8E91] max-w-2xl mx-auto text-base md:text-lg mt-3">
        Train, deploy, and scale on the world's most cost-effective decentralized cloud.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 -mx-4">
      {features.map((feature) => (
        <div class="feature-card relative overflow-hidden">

          <!-- Desktop / Tablet -->
          <picture class="feature-img-desktop">
            <source srcset={feature.imageWebp} type="image/webp" />
            <img
              src={feature.image}
              alt={feature.title}
              width="1437"
              height="892"
              loading="lazy"
              decoding="async"
              class="w-full h-auto select-none pointer-events-none max-w-2xs md:max-w-full"
            />
          </picture>

          <!-- Mobile -->
          <picture class="feature-img-mobile">
            <source srcset={feature.mobileImageWebp} type="image/webp" />
            <img
              src={feature.mobileImage}
              alt={feature.title}
              width="770"
              height="800"
              loading="lazy"
              decoding="async"
              class="w-full h-auto object-cover select-none pointer-events-none"
            />
          </picture>

          <!-- Content -->
          <div class="feature-content absolute bottom-[15%] space-y-2 max-w-[80%]">
            <h3 class="text-[22px] md:text-[28px] text-white font-semibold flex items-center gap-2">
              {feature.title}
            </h3>

            <p class="text-sm md:text-base text-white font-medium">
              {feature.description.primary} <span class="text-[#8C8E91] font-normal">{feature.description.secondary}</span>
            </p>
          </div>

        </div>
      ))}
    </div>
</section>

<style>
  picture.feature-img-mobile {
    display: none;
  }
  picture.feature-img-desktop {
    display: block;
  }
  .feature-content {
    left: 7%;
  }

  /* Reserve space for images before they load to prevent layout shift */
  .feature-card {
    aspect-ratio: 1437 / 892;
  }

  @media (max-width: 450px) {
    picture.feature-img-mobile {
      display: block;
    }
    picture.feature-img-desktop {
      display: none;
    }
    .feature-content {
      left: 10%;
    }
    .feature-card {
      aspect-ratio: 770 / 800;
    }
  }
</style>