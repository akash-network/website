---
import TrustedByMarquee from "../TrustedByMarquee";
import { trustedBySection } from "./trustedby";
---

<div class="w-full overflow-hidden py-16 bg-background dark:bg-[#030303] md:py-20">
  <div class="container flex flex-col items-center">
    <!-- Marquee with edge fades aligned to container -->
    <div
      class="relative mb-10 w-full md:before:absolute md:before:left-0 md:before:top-0 md:before:z-10 md:before:h-full md:before:w-24 md:before:bg-gradient-to-r md:before:from-white md:before:to-transparent md:before:content-[''] md:after:absolute md:after:right-0 md:after:top-0 md:after:z-10 md:after:h-full md:after:w-24 md:after:bg-gradient-to-l md:after:from-white md:after:to-transparent md:after:content-[''] dark:md:before:from-[#030303] dark:md:after:from-[#030303]"
    >
      <div style="min-height:34px;">
        <TrustedByMarquee trustedBySection={trustedBySection} client:only="react" />
      </div>
    </div>

    <a
      href="https://www.razer.ai/aikit-akash-avamini/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-foreground/5"
    >
      Read Razer Case Study
      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
      </svg>
    </a>
  </div>
</div>
