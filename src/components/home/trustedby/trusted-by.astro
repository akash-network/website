---
import TrustedByMarquee from "../TrustedByMarquee";
import { trustedBySection } from "./trustedby";
---

<div class="w-full overflow-hidden pt-16 pb-10 bg-background dark:bg-[#030303] md:py-20">
<style>
  @media (min-width: 768px) {
    .marquee-wrapper::before,
    .marquee-wrapper::after {
      content: '';
      position: absolute;
      top: 0;
      z-index: 10;
      height: 100%;
      width: 180px;
      pointer-events: none;
    }
    .marquee-wrapper::before {
      left: 0;
      background: linear-gradient(to right,
        white 0%,
        white 25%,
        rgba(255,255,255,0.85) 45%,
        rgba(255,255,255,0.6) 60%,
        rgba(255,255,255,0.3) 75%,
        rgba(255,255,255,0.08) 90%,
        transparent 100%
      );
    }
    .marquee-wrapper::after {
      right: 0;
      background: linear-gradient(to left,
        white 0%,
        white 25%,
        rgba(255,255,255,0.85) 45%,
        rgba(255,255,255,0.6) 60%,
        rgba(255,255,255,0.3) 75%,
        rgba(255,255,255,0.08) 90%,
        transparent 100%
      );
    }
    :global(.dark) .marquee-wrapper::before {
      background: linear-gradient(to right,
        #030303 0%,
        #030303 25%,
        rgba(3,3,3,0.85) 45%,
        rgba(3,3,3,0.6) 60%,
        rgba(3,3,3,0.3) 75%,
        rgba(3,3,3,0.08) 90%,
        transparent 100%
      );
    }
    :global(.dark) .marquee-wrapper::after {
      background: linear-gradient(to left,
        #030303 0%,
        #030303 25%,
        rgba(3,3,3,0.85) 45%,
        rgba(3,3,3,0.6) 60%,
        rgba(3,3,3,0.3) 75%,
        rgba(3,3,3,0.08) 90%,
        transparent 100%
      );
    }
  }
</style>
  <!-- Marquee — full bleed on mobile, edge fades aligned to container on desktop -->
  <div class="marquee-wrapper relative mb-10 w-full md:container md:mx-auto">
    <div style="min-height:34px;">
      <TrustedByMarquee trustedBySection={trustedBySection} client:only="react" />
    </div>
  </div>

  <div class="container flex justify-center" style="position:relative;z-index:1;">
    <a
      href="https://www.razer.ai/aikit-akash-avamini/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-foreground/5"
    >
      Read Razer Case Study
      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
      </svg>
    </a>
  </div>
</div>
