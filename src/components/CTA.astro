---
import { shouldHideCta } from "@/utils/hideCta";
import clsx from "clsx";

const pathname = Astro.url.pathname;
const disableMargin = ["/deploy", "/providers"];
const defaultContent = {
  title: "Experience the Supercloud.",
  button: {
    label: "Deploy Now",
    link: "https://console.akash.network/",
    id: "console-home",
  },
};

const pathContent = {
  "/about/providers": {
    title: "Join the Supercloud",
    button: {
      label: "Become a Provider",
      link: "/providers",
      id: "provider-home",
    },
  },
  "/ecosystem/providers": {
    title: "Join the Supercloud Provider Network",
    button: {
      label: "Become a Provider",
      link: "/about/providers/",
      id: "provider-ecosystem",
    },
  },
};

const content = pathname.startsWith("/about/providers")
  ? pathContent["/about/providers"]
  : pathname.startsWith("/ecosystem/providers")
    ? pathContent["/ecosystem/providers"]
    : defaultContent;

const { title, button } = content;

const shouldHide = shouldHideCta(pathname);
---

<section
  class={clsx(
    shouldHide && "hidden",
    (pathname === "/" || pathname.startsWith("/meetingconfirmation")) && "hidden",
    "flex flex-col items-center justify-around",
    "bg-gray-50 dark:bg-background2",
    "border-y",
    "px-[30px] py-[80px] lg:py-[160px]",
    disableMargin.includes(pathname) ? "mt-0" : "mt-20",
    "text-center",
  )}
>
  <h2
    class={clsx(
      "max-w-[1000px] font-sans font-semibold tracking-tight text-foreground",
      "text-3xl md:text-5xl xl:text-6xl",
      "md:leading-snug",
    )}
  >
    {title}
  </h2>

  <div class="mt-6 md:mt-10">
    <a
      href={button.link}
      id={button.id}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center rounded-md bg-foreground px-5 py-2.5 text-sm font-medium text-background transition-opacity hover:opacity-80"
    >
      {button.label}
    </a>
  </div>
</section>
