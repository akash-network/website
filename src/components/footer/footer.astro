---
import FooterLink from "@/components/footer/footer-link.astro";
import { socialLinks } from "@/lib/constants";
import { shouldHideCta } from "@/utils/hideCta";
import clsx from "clsx";

import DarkModeToggle from "../dark-mode-toggle";
import {
  DiscordIcon,
  GithubIcon,
  InstagramIcon,
  LinkedInIcon,
  TelegramIcon,
  TwitterIcon,
  YoutubeIcon,
} from "../header/icons";
import Logo from "../ui/logo.astro";
import FooterYear from "./footer-year";
import { FooterInlineNewsletter } from "./FooterInlineNewsletter";

type Props = {
  overrideClassName?: string;
  hideDarkToggle?: boolean;
};

const { overrideClassName, hideDarkToggle }: Props = Astro.props;

const socials = [
  {
    name: "Twitter",
    link: socialLinks.twitter,
    icon: TwitterIcon,
  },
  {
    name: "Github",
    link: socialLinks.github,
    icon: GithubIcon,
  },
  {
    name: "Discord",
    link: socialLinks.discord,
    icon: DiscordIcon,
  },
  {
    name: "Youtube",
    link: socialLinks.youtube,
    icon: YoutubeIcon,
  },
  {
    name: "Telegram",
    link: socialLinks.telegram,
    icon: TelegramIcon,
  },
  {
    name: "Instagram",
    link: socialLinks.instagram,
    icon: InstagramIcon,
  },
  {
    name: "LinkedIn",
    link: socialLinks.linkedin,
    icon: LinkedInIcon,
  },
];

const links = [
  {
    title: "Resources",
    links: [
      {
        title: "Economics Paper",
        link: "/economics",
      },
      {
        title: "White Paper",
        link: "/whitepaper",
      },
      {
        title: "Blog",
        link: "/blog",
      },
      {
        title: "Brand & Press",
        link: "/brand/resources/",
      },
    ],
  },
  {
    title: "Network",
    links: [
      {
        title: "About Akash",
        link: "/about/general-information/",
      },
      {
        title: "AKT Token",
        link: "/token",
      },
      {
        title: "Compute Providers",
        link: "/ecosystem/providers/",
      },
      {
        title: "Akash Validators",
        link: "/network/akash-validators/",
      },
    ],
  },
  {
    title: "Community",
    links: [
      {
        title: "Join the Movement",
        link: "/community/welcome/",
      },
      {
        title: "Community Contributions",
        link: "/community/contributions/",
      },
      {
        title: "Events & Meetups",
        link: "/community/events",
      },
      {
        title: "Student Ambassadors",
        link: "/community/student-ambassadors/",
      },
    ],
  },
  {
    title: "Development",
    links: [
      {
        title: "Documentation",
        link: "/docs",
      },
      {
        title: "Developer Portal",
        link: "/development/welcome/",
      },
      {
        title: "Roadmap",
        link: "/roadmap/",
      },
      {
        title: "Community Groups",
        link: "/development/community-groups/",
      },
      {
        title: "Discussions",
        link: "https://github.com/orgs/akash-network/discussions",
      },
    ],
  },
  {
    title: "Product Suite",
    links: [
      {
        title: "Akash Console",
        link: "https://console.akash.network/",
      },
      {
        title: "AkashML",
        link: "https://akashml.com/",
      },
      {
        title: "Akash Provider Console",
        link: "https://provider-console.akash.network/",
      },
      {
        title: "Akash Chat",
        link: "https://chat.akash.network/",
      },
    ],
  },
];

const pathname = Astro.url.pathname;

const shouldHide = shouldHideCta(pathname);
---

<footer
  class={clsx(
    " w-full pb-10 text-white ",
    shouldHide && "border-t  mt-20",
    overrideClassName
      ? overrideClassName
      : "bg-white dark:bg-background container"
  )}
>
  <div class="border-b pb-10 md:pb-20 flex flex-col gap-10">

    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border-b border-zinc-200 dark:border-white/10 py-10">
      <a href="/">
        <Logo width={95} />
      </a>
      <div class="flex flex-wrap items-center justify-start sm:justify-end gap-3 md:gap-4">
        {
          socials.map((social) => (
            <a
              aria-label={`Akash Network ${social.name}`}
              href={social.link}
              target="_blank"
              class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
            >
              <social.icon />
            </a>
          ))
        }
        {
          !hideDarkToggle && (
            <>
              <div class="h-5 w-px bg-zinc-200 dark:bg-zinc-700" />
              <DarkModeToggle footer client:load />
            </>
          )
        }
      </div>
    </div>

    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between border-b border-zinc-200 dark:border-white/10 pb-10">
      <div class="flex flex-col gap-1">
        <p class="text-sm font-medium text-foreground">Subscribe to our newsletter</p>
        <p class="text-[13px] text-zinc-500">Get the latest news and updates.</p>
      </div>
      <div class="md:max-w-sm w-full">
        <FooterInlineNewsletter client:load />
      </div>
    </div>

    <div class="grid grid-cols-2 justify-between gap-y-10 md:grid-cols-5 md:gap-x-5">
      {
        links.map((link) => (
          <div>
            <p class="text-sm font-medium text-foreground">
              {link.title}
            </p>
            {link.links.map((item) => (
              <FooterLink aria-label={item.title} link={item.link}>
                {item.title}
              </FooterLink>
            ))}
          </div>
        ))
      }
    </div>

  </div>
  <div class="relative flex flex-col justify-center pt-6 text-center">
    <div
      class="flex w-full flex-col items-center justify-center gap-y-[16px] lg:flex-row lg:items-center"
    >
      <p
        class="text-center text-2xs text-linkText md:text-left lg:border-r lg:pr-[16px]"
      >
        © Akash Network <FooterYear client:load />
        The Akash Network Authors Documentation Distributed under CC BY 4.0
      </p>
      <div class="flex">
        <p class="border-r pr-[8px] text-2xs text-linkText lg:px-[16px]">
          <a
            aria-label="Open-source Apache 2.0 Licensed."
            class="text-decoration-none"
            target="_blank"
            href="https://github.com/akash-network"
          >
            Open-source Apache 2.0 Licensed.
          </a>
        </p>
        <p class="border-r px-[8px] text-2xs text-linkText lg:px-[16px]">
          <a
            aria-label="GitHub v0.38.2"
            class="text-decoration-none"
            target="_blank"
            href="https://github.com/akash-network/node"
          >
            GitHub v0.38.2
          </a>
        </p>

        <p class="pl-[8px] text-2xs text-linkText lg:pl-[16px]">
          <a
            aria-label="Privacy"
            class="text-decoration-none"
            target="_blank"
            href="/privacy"
          >
            Privacy
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
