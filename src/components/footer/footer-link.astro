---
interface Props {
  link: string;
  "aria-label"?: string;
  id?: string;
}

const { link, "aria-label": ariaLabel, id } = Astro.props;
---

<p class="mt-2 text-left md:mt-[16px]">
  <a
    id={id}
    aria-label={`${ariaLabel ?? "footer link"}`}
    class="text-[13px] font-normal text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors"
    target={link ? (link.startsWith("http") ? "_blank" : "_self") : "_self"}
    href={link}
  >
    <slot />
  </a>
</p>
