---
import NavLink from "@/components/header/nav-link.astro";
import Logo from "@/components/ui/logo.astro";
import { getYearToUse } from "@/utils/redirects";
import clsx from "clsx";

import TryAkashForm from "../ui/try-akash-form";
import HamburgerMenu from "./hamburger-menu";
import NavMenu from "./nav-menu";
import { SubNavbar } from "./popovers/popover-nav-community";

const pathname = `/${Astro.url.pathname.split("/")[1]}`;
const isValidatorsPage = Astro.url.pathname.startsWith("/network/akash-validators");
const isProvidersPage = Astro.url.pathname.startsWith("/ecosystem/providers");

interface Props {
  disableSticky?: boolean;
  hideDarkToggle?: boolean;
  overrideClassName?: string;
  hideContainer?: boolean;
  navClassName?: string;
}

const {
  disableSticky,
  hideDarkToggle,
  overrideClassName,
  hideContainer,
  navClassName,
} = Astro.props;

const visibility = {
  network: ["/about", "/token", "/network"],
  community: ["/community"],
  development: ["/development", "/roadmap"],
  ecosystem: ["/ecosystem", "/case-studies"],
  pricing: ["/pricing"],
};

const pathnames = Object.values(visibility).flat();
const latestRoadmapYear = getYearToUse();
const isPathInNavigation = pathnames.includes(pathname) || isValidatorsPage || isProvidersPage;

// Header is sticky on ALL pages (not just non-nav pages)
const stickyClass = !disableSticky ? "top-0 sticky z-[40]" : "";
const headerBaseClass = "pt-4 pb-2.5 px-4 transition-transform duration-300";
const headerClass = overrideClassName
  ? clsx(overrideClassName, "transition-transform duration-300")
  : clsx(headerBaseClass, stickyClass);

// Sub-nav container is sticky; breadcrumb is rendered separately above it
const navContainerVisibility = disableSticky
  ? "hidden"
  : pathnames.includes(pathname)
    ? "top-0 sticky z-[30]"
    : "hidden";

const navContainerClass = hideContainer ? "" : "container";

---

<header class={headerClass} id="main-header">
  <nav
    class={clsx(
      "relative z-[40] bg-background mx-auto flex h-[56px] items-center rounded-xl border border-zinc-200 dark:border-white/10 px-4 md:px-6",
      navContainerClass,
      navClassName,
    )}
    id="page-top"
  >
    <!-- Logo -->
    <div class="flex flex-shrink-0 items-center">
      <a href="/">
        <span class="hidden md:block"><Logo width={95} /></span>
        <span class="block md:hidden"><Logo width={85} height={18} /></span>
      </a>
    </div>

    <!-- Center: desktop nav links -->
    <div class="absolute left-1/2 hidden h-full -translate-x-1/2 items-center gap-x-[20px] slg:flex xl:gap-x-[24px]">
      <NavMenu
        client:idle
        latestRoadmapYear={latestRoadmapYear}
        pathname={pathname}
      />
      <NavLink href="/blog/" currentPath={pathname}>Blog</NavLink>
      <NavLink href="/docs/" currentPath={pathname}>Docs</NavLink>
      <NavLink href="/pricing/gpus" currentPath={pathname}>Pricing</NavLink>
    </div>

    <!-- Right: hamburger (mobile) + buttons (desktop) -->
    <div class="ml-auto flex flex-shrink-0 items-center gap-2">
      <div class="block overflow-hidden slg:hidden">
        <HamburgerMenu
          client:media="(max-width: 1099px)"
          currentPath={pathname}
          latestRoadmapYear={latestRoadmapYear}
          hideDarkToggle={hideDarkToggle}
        />
      </div>

      <div class="hidden slg:flex items-center gap-2">
        <a
          href="/gpus-on-demand"
          class="inline-flex items-center justify-center rounded-md bg-zinc-100 dark:bg-zinc-800 px-[11px] py-[7px] text-xs font-medium text-zinc-700 dark:text-zinc-300 transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-700"
        >
          Get in Touch
        </a>
        <TryAkashForm client:idle type="headerDeploy" />
      </div>
    </div>
  </nav>
</header>

{isPathInNavigation && <div class="h-[60px]" />}

<!-- Sub-nav items bar: sticky -->
<div id="sub-nav-container" class={navContainerVisibility}>
  {
    (visibility.network.includes(pathname) || isValidatorsPage) && !isProvidersPage && (
      <SubNavbar pathname={Astro.url.pathname} client:load type="network" />
    )
  }
  {
    (visibility.community.includes(pathname) && !isValidatorsPage) && (
      <SubNavbar pathname={Astro.url.pathname} client:load type="community" />
    )
  }
  {
    visibility.development.includes(pathname) && (
      <SubNavbar pathname={Astro.url.pathname} client:load type="development" />
    )
  }
  {
    (visibility.ecosystem.includes(pathname) || isProvidersPage) && (
      <SubNavbar pathname={Astro.url.pathname} client:load type="ecosystem" />
    )
  }
  {
    visibility.pricing.includes(pathname) && (
      <SubNavbar pathname={Astro.url.pathname} client:load type="pricing" />
    )
  }
</div>

{isPathInNavigation && (
  <style>
    /* Prevent layout shift before SubNavbar island hydrates */
    #sub-nav-container {
      min-height: 44px;
    }
  </style>
)}

<script>
  function setupNavScroll() {
    const header = document.getElementById("main-header");
    if (!header) return;

    const isSticky = window.getComputedStyle(header).position === "sticky";
    if (!isSticky) return;

    const subNav = document.getElementById("sub-nav-container");
    const hasSubNav = subNav && !subNav.classList.contains("hidden");

    let lastY = window.scrollY;
    let rafId: number;

    const onScroll = () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        const y = window.scrollY;
        if (y > lastY && y > 80) {
          header.style.transform = "translateY(-100%)";
        } else if (y < lastY) {
          if (!hasSubNav || y < 80) {
            header.style.transform = "";
          }
        }
        lastY = y;
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", onScroll);
        cancelAnimationFrame(rafId);
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", setupNavScroll);
</script>
